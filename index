  <!-- Python: cała logika interakcji -->
  <script type="py">
from dataclasses import dataclass
from datetime import datetime
from random import choice, randint
from pyscript import document, window

@dataclass
class Episode:
    id: str
    title: str
    guest: str
    kind: str     # "Wywiad" | "Solo" | "Panel"
    minutes: int
    date: str
    blurb: str

class State:
    def __init__(self):
        self.filtered = []
        self.current_index = 0
        self.playing = False
        self.progress = 0.0  # 0..1
        self.timer_id = None

state = State()

episodes = [
    Episode("ep-001", "Pierwsze 10 minut odcinka: jak nie spalić energii", "Marta (host)", "Solo", 18, "2026-03-02", "Rytm intro, teza, obietnica i cięcie ciszy."),
    Episode("ep-002", "Wywiad bez small talku: pytania, które otwierają rozmówcę", "Ola K.", "Wywiad", 42, "2026-03-06", "Struktura rozmowy + prowadzenie w stresie."),
    Episode("ep-003", "Montaż: minimalizm, który brzmi drogo", "Kuba S.", "Wywiad", 55, "2026-03-10", "Czyszczenie, oddechy, muzyka, głośność, mastering."),
    Episode("ep-004", "Panel: kiedy 3 osoby to za dużo (i jak to uratować)", "Zespół: Ania / Bartek / Iga", "Panel", 47, "2026-03-12", "Moderacja, zasady, sygnały i przerwania."),
    Episode("ep-005", "Reklamy w podcaście: jak nie brzmieć jak ulotka", "Paweł R.", "Wywiad", 38, "2026-03-16", "Integracje, autentyczność i granice sponsora."),
    Episode("ep-006", "Solo: jak pisać scenariusz, żeby brzmiał naturalnie", "Marta (host)", "Solo", 26, "2026-03-19", "Pisanie do mówienia: rytm, pauzy, akcenty."),
]

# --- DOM helpers ---
def el(id_):
    return document.getElementById(id_)

def fmt_time(total_seconds: int) -> str:
    m = total_seconds // 60
    s = total_seconds % 60
    return f"{m:02d}:{s:02d}"

def clamp(x, a, b):
    return max(a, min(b, x))

# --- Rendering ---
def render_meta(count: int, total: int):
    q = el("q").value.strip()
    kind = el("kind").value
    label = f"Wyniki: {count}/{total}"
    if q:
        label += f" • fraza: „{q}”"
    if kind != "Wszystkie":
        label += f" • typ: {kind}"
    el("resultMeta").textContent = label

def tag_class(kind: str) -> str:
    return {"Wywiad":"i", "Solo":"p", "Panel":"s"}.get(kind, "i")

def render_list(items):
    container = el("episodesList")
    container.innerHTML = ""
    total = len(episodes)

    if not items:
        container.innerHTML = (
            "<div class='episode' style='grid-template-columns:1fr; padding:14px;'>"
            "<div class='epTitle'><strong>Brak wyników</strong>"
            "<small>Spróbuj innej frazy lub przełącz filtr.</small></div>"
            "</div>"
        )
        render_meta(0, total)
        return

    for idx, e in enumerate(items):
        # Build row
        row = document.createElement("article")
        row.className = "episode"
        row.setAttribute("role", "button")
        row.setAttribute("tabindex", "0")
        row.setAttribute("aria-label", f"Wybierz odcinek: {e.title}")

        title = document.createElement("div")
        title.className = "epTitle"
        title.innerHTML = f"<strong>{e.title}</strong><small>{e.guest} • {e.blurb}</small>"

        tag = document.createElement("div")
        tag.className = f"tag {tag_class(e.kind)}"
        tag.textContent = e.kind

        meta = document.createElement("div")
        meta.className = "epMeta"
        meta.textContent = f"{e.date} • {e.minutes} min"

        btn = document.createElement("button")
        btn.className = "btn"
        btn.type = "button"
        btn.textContent = "Wybierz"
        btn.style.padding = "9px 12px"
        btn.style.boxShadow = "none"

        def make_onpick(local_id):
            def onpick(evt=None):
                pick_by_id(local_id)
            return onpick

        onpick = make_onpick(e.id)
        btn.addEventListener("click", onpick)
        row.addEventListener("click", onpick)

        def on_key(evt, f=onpick):
            # Enter/Space
            if evt.key in ["Enter", " "]:
                evt.preventDefault()
                f(evt)
        row.addEventListener("keydown", on_key)

        row.appendChild(title)
        row.appendChild(tag)
        row.appendChild(meta)
        row.appendChild(btn)

        container.appendChild(row)

    render_meta(len(items), total)

def filter_episodes(query: str, kind: str):
    q = (query or "").strip().lower()
    res = []
    for e in episodes:
        ok_q = (q == "") or (q in e.title.lower()) or (q in e.guest.lower()) or (q in e.blurb.lower())
        ok_k = (kind == "Wszystkie") or (e.kind == kind)
        if ok_q and ok_k:
            res.append(e)
    # newest first (string YYYY-MM-DD works lexicographically)
    res.sort(key=lambda x: x.date, reverse=True)
    return res

# --- Player (simulated) ---
def current_items():
    return state.filtered if state.filtered else filter_episodes(el("q").value, el("kind").value)

def get_current_episode():
    items = current_items()
    if not items:
        return None, items
    state.current_index = clamp(state.current_index, 0, len(items)-1)
    return items[state.current_index], items

def set_player_episode(e: Episode):
    el("nowTitle").textContent = e.title
    el("nowMeta").textContent = f"{e.kind} • {e.guest} • {e.date} • {e.minutes} min"
    el("tDur").textContent = fmt_time(e.minutes * 60)

def render_player():
    e, _ = get_current_episode()
    if e is None:
        el("nowTitle").textContent = "—"
        el("nowMeta").textContent = "Wybierz odcinek z archiwum poniżej"
        el("tCur").textContent = "00:00"
        el("tDur").textContent = "--:--"
        el("progressFill").style.width = "0%"
        el("btnPlay").textContent = "▶"
        el("btnPlayTop").textContent = "Odtwórz"
        return

    set_player_episode(e)
    dur = e.minutes * 60
    cur = int(state.progress * dur)
    el("tCur").textContent = fmt_time(cur)
    el("progressFill").style.width = f"{int(state.progress*100)}%"
    el("progressFill").parentElement.setAttribute("aria-valuenow", str(int(state.progress*100)))

    el("btnPlay").textContent = "⏸" if state.playing else "▶"
    el("btnPlayTop").textContent = "Pauza" if state.playing else "Odtwórz"

def stop_timer():
    if state.timer_id is not None:
        window.clearInterval(state.timer_id)
        state.timer_id = None

def tick():
    e, _ = get_current_episode()
    if e is None:
        stop_timer()
        state.playing = False
        render_player()
        return

    dur = e.minutes * 60
    # advance by 0.5s
    state.progress += (0.5 / dur) if dur > 0 else 0
    if state.progress >= 1.0:
        state.progress = 0.0
        state.playing = False
        stop_timer()
    render_player()

def toggle_play():
    e, _ = get_current_episode()
    if e is None:
        # auto-pick first available
        items = current_items()
        if items:
            state.current_index = 0
            state.progress = 0.0
            e, _ = get_current_episode()
        else:
            return

    state.playing = not state.playing
    if state.playing:
        stop_timer()
        state.timer_id = window.setInterval(tick, 500)
    else:
        stop_timer()
    render_player()

def next_ep():
    e, items = get_current_episode()
    if not items:
        return
    state.current_index = (state.current_index + 1) % len(items)
    state.progress = 0.0
    render_player()

def prev_ep():
    e, items = get_current_episode()
    if not items:
        return
    state.current_index = (state.current_index - 1) % len(items)
    state.progress = 0.0
    render_player()

def pick_by_id(ep_id: str):
    items = current_items()
    if not items:
        return
    for i, e in enumerate(items):
        if e.id == ep_id:
            state.current_index = i
            state.progress = 0.0
            state.playing = False
            stop_timer()
            render_player()
            return

def clear_filters():
    el("q").value = ""
    el("kind").value = "Wszystkie"
    state.filtered = filter_episodes("", "Wszystkie")
    state.current_index = 0
    state.progress = 0.0
    state.playing = False
    stop_timer()
    render_list(state.filtered)
    render_player()

def update_filters():
    q = el("q").value
    k = el("kind").value
    state.filtered = filter_episodes(q, k)
    state.current_index = 0
    state.progress = 0.0
    state.playing = False
    stop_timer()
    render_list(state.filtered)
    render_player()

def random_pick():
    items = current_items()
    if not items:
        return
    picked = choice(items)
    pick_by_id(picked.id)

def add_sample_episode():
    # Add one more episode programmatically to show "Python-only" behavior.
    new_id = f"ep-{randint(100,999)}"
    kinds = ["Wywiad","Solo","Panel"]
    k = choice(kinds)
    title = choice([
        "Jak dociąć pauzy, żeby rozmowa oddychała",
        "Gość mówi za długo: eleganckie przerwania",
        "Intro, które nie kradnie odcinka",
        "Storytelling w podcaście: napięcie bez melodramatu",
        "Czytanie z kartki, które brzmi jak rozmowa",
    ])
    guest = choice(["Kasia M.", "Tomek P.", "Natalia Z.", "Michał W.", "Marta (host)"])
    minutes = choice([22, 29, 33, 41, 48])
    today = datetime.now().strftime("%Y-%m-%d")
    blurb = "Nowy wpis dodany z poziomu przeglądarki przez Python."

    episodes.append(Episode(new_id, title, guest, k, minutes, today, blurb))
    update_filters()

# --- Bind events ---
def bind():
    el("q").addEventListener("input", lambda evt: update_filters())
    el("kind").addEventListener("change", lambda evt: update_filters())
    el("btnClear").addEventListener("click", lambda evt: clear_filters())

    el("btnPlay").addEventListener("click", lambda evt: toggle_play())
    el("btnPlayTop").addEventListener("click", lambda evt: toggle_play())
    el("btnNext").addEventListener("click", lambda evt: next_ep())
    el("btnPrev").addEventListener("click", lambda evt: prev_ep())

    el("btnSeed").addEventListener("click", lambda evt: random_pick())
    el("btnAddSample").addEventListener("click", lambda evt: add_sample_episode())

def init():
    el("year").textContent = str(datetime.now().year)
    state.filtered = filter_episodes("", "Wszystkie")
    render_list(state.filtered)
    render_player()
    bind()
    el("pyStatus").textContent = "Python gotowy • interakcje działają"

init()
  </script>

  <!-- Minimal JS: tylko scroll-reveal w razie gdybyś dodawał nowe elementy później -->
  <script>
    // IntersectionObserver for future elements (optional)
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.style.animationPlayState = 'running';
          io.unobserve(e.target);
        }
      }
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach(el => {
      // Already animated on load; keep observer for any future dynamic reveal nodes
      io.observe(el);
    });
  </script>
